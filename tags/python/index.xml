<span class="n">bitNot</span> <span class="o">=</span> <span class="n">cv2</span><span class="o">.</span><span class="n">bitwise_not</span><span class="p">(</span><span class="n">img1</span><span class="p">)</span>
</code></pre></td></tr></table>
